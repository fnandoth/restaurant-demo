---
const currentYear = new Date().getFullYear();
---

<footer style="font-family: var(--font-body); background: var(--color-surface); color: var(--color-text-primary);">
  <div class="footer-inner">
    <div class="footer-brand">
      <!-- <img
        src="/assets/mini-logotipo.png"
        alt="Gran Café Santander"
        width="120"
        height="40"
        loading="lazy"
        decoding="async"
      /> -->
      <p class="footer-tagline">Sabores del norte, alma madrileña.</p>
      <div class="footer-social">
        <a href="https://www.instagram.com/grancafe.santander/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.facebook.com/grancafesantander" target="_blank" rel="noopener noreferrer">Facebook</a>
      </div>
    </div>
    <div class="footer-contact">
      <h3>Contacto</h3>
      <p>Plaza de Santa Bárbara, 4 · Madrid 28004</p>
      <p>Tel. 914 457 295</p>
      <p>Mon–Fri 08:00–01:00 / Sat–Sun 09:00–01:00</p>
    </div>
    <div class="footer-nav">
      <h3>Trabaja con nosotros</h3>
      <a href="/trabaja-con-nosotros">Enviar candidatura</a>
    </div>
    <div class="footer-legal">
      <h3>Legal</h3>
      <a href="/aviso-legal">Aviso Legal</a>
      <a href="/politica-de-privacidad">Política de Privacidad</a>
      <a href="/politica-de-cookies">Política de Cookies</a>
    </div>
  </div>

  <div class="footer-bottom">
    © {currentYear} Gran Café Santander. Todos los derechos reservados.
  </div>
</footer>

<style>
  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 4rem 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .footer-inner h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
  }

  .footer-tagline {
    margin-top: 1rem;
    color: var(--color-text-muted);
  }

  .footer-social {
    margin-top: 1rem;
    display: flex;
    gap: 1rem;
  }

  .footer-inner a {
    color: inherit;
    text-decoration: none;
    transition: color 300ms ease-out;
  }

  .footer-inner a:hover {
    color: var(--color-brand);
  }

  .footer-nav,
  .footer-contact,
  .footer-legal {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-bottom {
    background: var(--color-brand-dark);
    color: var(--color-surface);
    text-align: center;
    padding: 1rem 1.5rem;
    font-size: 0.9rem;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
    }
  }
</style>
