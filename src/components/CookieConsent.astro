---
import "../styles/CookieConsent.css";
---

<div id="cookie-consent" class="cookie-consent" hidden aria-hidden="true">
  <div class="cookie-overlay"></div>
  <div
    class="cookie-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cookie-title"
    aria-describedby="cookie-description"
  >
    <h2 id="cookie-title">Preferencias de cookies</h2>
    <p id="cookie-description">
      Utilizamos cookies propias y de terceros para mejorar tu experiencia,
      analizar el tráfico y personalizar contenidos. Puedes aceptar todas,
      rechazarlas o configurar tus preferencias. Más información en nuestra
      <a href="/politica-de-cookies">Política de Cookies</a>.
    </p>

    <div class="cookie-actions">
      <button class="cookie-button" type="button" data-action="accept"
        >Aceptar todas</button
      >
      <button class="cookie-button" type="button" data-action="reject"
        >Rechazar</button
      >
      <button
        class="cookie-link"
        type="button"
        data-action="configure"
        aria-expanded="false"
        aria-controls="cookie-preferences-panel"
      >
        Configurar
      </button>
    </div>

    <div id="cookie-preferences-panel" class="cookie-preferences" hidden>
      <div class="cookie-option">
        <label>
          <input type="checkbox" checked disabled />
          <span>
            Cookies técnicas / esenciales
            <small>Necesarias para el funcionamiento del sitio.</small>
          </span>
        </label>
      </div>
      <div class="cookie-option">
        <label>
          <input id="cookie-analytics" type="checkbox" />
          <span>
            Cookies analíticas
            <small>Google Analytics (_ga, _gat, _gid).</small>
          </span>
        </label>
      </div>
      <div class="cookie-option">
        <label>
          <input id="cookie-preferences" type="checkbox" />
          <span>
            Cookies de preferencias
            <small>Recuerdan tus ajustes de navegación.</small>
          </span>
        </label>
      </div>
      <button class="cookie-button" type="button" data-action="save"
        >Guardar preferencias</button
      >
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = "cookie_consent";
  const EXPIRY_DAYS = 365;
  const consentModal = document.getElementById("cookie-consent");

  if (consentModal) {
    const acceptButton = consentModal.querySelector('[data-action="accept"]');
    const rejectButton = consentModal.querySelector('[data-action="reject"]');
    const configureButton = consentModal.querySelector(
      '[data-action="configure"]',
    );
    const saveButton = consentModal.querySelector('[data-action="save"]');
    const preferencesPanel = document.getElementById(
      "cookie-preferences-panel",
    );
    const analyticsToggle = document.getElementById("cookie-analytics");
    const preferencesToggle = document.getElementById("cookie-preferences");
    let isOpen = false;
    let lastFocused: Element | null = null;

    const parseStoredConsent = () => {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      try {
        return JSON.parse(raw);
      } catch (error) {
        console.warn(
          "Consentimiento de cookies inválido. Se restablece.",
          error,
        );
        localStorage.removeItem(STORAGE_KEY);
        return null;
      }
    };

    const isConsentExpired = (stored: { date: string | number | Date }) => {
      if (!stored?.date) return false;
      const storedDate = new Date(stored.date);
      if (Number.isNaN(storedDate.getTime())) return false;
      const ageMs = Date.now() - storedDate.getTime();
      return ageMs > EXPIRY_DAYS * 24 * 60 * 60 * 1000;
    };

    const applyStoredPreferences = (stored: {
      analytics: any;
      preferences: any;
    }) => {
      if (analyticsToggle) analyticsToggle.checked = Boolean(stored?.analytics);
      if (preferencesToggle)
        preferencesToggle.checked = Boolean(stored?.preferences);
    };

    const setPreferencesOpen = (open: boolean) => {
      if (!preferencesPanel) return;
      preferencesPanel.hidden = !open;
      configureButton?.setAttribute("aria-expanded", open ? "true" : "false");
    };

    const showModal = (openPreferences = false) => {
      if (isOpen) return;
      lastFocused = document.activeElement;
      consentModal.hidden = false;
      consentModal.setAttribute("aria-hidden", "false");
      isOpen = true;
      setPreferencesOpen(openPreferences);
      window.setTimeout(() => {
        const target = openPreferences ? analyticsToggle : acceptButton;
        (target || consentModal).focus();
      }, 0);
    };

    const hideModal = () => {
      consentModal.hidden = true;
      consentModal.setAttribute("aria-hidden", "true");
      isOpen = false;
      setPreferencesOpen(false);
      if (lastFocused && typeof lastFocused.focus === "function") {
        lastFocused.focus();
      }
    };

    const saveConsent = (analytics: boolean, preferences: boolean) => {
      const payload = {
        analytics,
        preferences,
        accepted: true,
        date: new Date().toISOString(),
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
      hideModal();
    };

    const handleAccept = () => saveConsent(true, true);
    const handleReject = () => saveConsent(false, false);
    const handleSavePreferences = () => {
      saveConsent(
        Boolean(analyticsToggle?.checked),
        Boolean(preferencesToggle?.checked),
      );
    };

    acceptButton?.addEventListener("click", handleAccept);
    rejectButton?.addEventListener("click", handleReject);
    saveButton?.addEventListener("click", handleSavePreferences);
    configureButton?.addEventListener("click", () => {
      setPreferencesOpen(true);
      analyticsToggle?.focus();
    });

    window.addEventListener("open-cookie-preferences", () => {
      const stored = parseStoredConsent();
      applyStoredPreferences(stored);
      showModal(true);
    });

    document.addEventListener("keydown", (event) => {
      if (!isOpen) return;
      if (event.key === "Escape") {
        event.preventDefault();
        handleReject();
      }
    });

    const stored = parseStoredConsent();
    if (stored && isConsentExpired(stored)) {
      localStorage.removeItem(STORAGE_KEY);
    }

    const validStored = parseStoredConsent();
    applyStoredPreferences(validStored);

    if (!validStored?.accepted) {
      showModal(false);
    }
  }
</script>
