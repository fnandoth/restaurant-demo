---
const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath === `${href}/`;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Gran Café Santander">
      <img
        src="/assets/logotipo-header.png"
        alt="Logo Gran Café Santander"
        width="190"
        height="48"
        loading="eager"
        decoding="async"
        style="max-height: 48px;"
      />
    </a>

    <div class="nav-links">
      <a href="/" class:list={{ 'nav-link': true, 'is-active': isActive('/') }}>Inicio</a>
      <a href="/carta" class:list={{ 'nav-link': true, 'is-active': isActive('/carta') }}>Carta</a>
      <a href="/reservas" class:list={{ 'nav-link': true, 'is-active': isActive('/reservas') }}>Reservas</a>
      <a href="/contacto" class:list={{ 'nav-link': true, 'is-active': isActive('/contacto') }}>Contacto</a>
      <a href="/reservas" class="nav-cta">Reservar mesa</a>
    </div>

    <details class="nav-details">
      <summary class="nav-summary" aria-label="Abrir menú" aria-expanded="false">
        <span>Menú</span>
        <span class="nav-burger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </summary>
      <div class="nav-panel">
        <a href="/" class:list={{ 'nav-link': true, 'is-active': isActive('/') }}>Inicio</a>
        <a href="/carta" class:list={{ 'nav-link': true, 'is-active': isActive('/carta') }}>Carta</a>
        <a href="/reservas" class:list={{ 'nav-link': true, 'is-active': isActive('/reservas') }}>Reservas</a>
        <a href="/contacto" class:list={{ 'nav-link': true, 'is-active': isActive('/contacto') }}>Contacto</a>
        <a href="/reservas" class="nav-cta">Reservar mesa</a>
      </div>
    </details>
  </div>
</nav>

<script>
  const nav = document.querySelector('.site-nav');
  const details = document.querySelector('.nav-details');
  const summary = details?.querySelector('summary');
  const threshold = 8;
  const setState = () => {
    if (!nav) return;
    const scrolled = window.scrollY > threshold;
    nav.classList.toggle('scrolled', scrolled);
  };
  const setExpanded = () => {
    if (!details || !summary) return;
    summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
  };
  setState();
  setExpanded();
  window.addEventListener('scroll', setState, { passive: true });
  window.addEventListener('resize', setState, { passive: true });
  details?.addEventListener('toggle', setExpanded);
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-warm-gray);
    transition: background-color 300ms ease-out, backdrop-filter 300ms ease-out, box-shadow 300ms ease-out;
  }

  .site-nav.scrolled {
    backdrop-filter: blur(12px);
    background-color: rgba(255, 255, 255, 0.88);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .nav-inner {
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0 1.5rem;
    height: var(--nav-height);
    max-width: var(--container-max);
    font-family: var(--font-body);
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 400;
    color: var(--color-text-primary);
    border-bottom: 2px solid transparent;
    padding-bottom: 0.25rem;
    transition: color 300ms ease-out, border-color 300ms ease-out;
  }

  .nav-link:hover {
    color: var(--color-brand);
  }

  .nav-link.is-active {
    border-color: var(--color-brand);
  }

  .nav-cta {
    background: var(--color-brand);
    color: var(--color-surface);
    padding: 0.7rem 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
    font-weight: 400;
    transition: background-color 300ms ease-out, transform 300ms ease-out;
  }

  .nav-cta:hover {
    background: var(--color-brand-dark);
    transform: translateY(-1px);
  }

  .nav-details {
    position: relative;
  }

  .nav-summary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
  }

  .nav-summary::-webkit-details-marker {
    display: none;
  }

  .nav-summary::marker {
    display: none;
  }

  .nav-burger span {
    display: block;
    width: 20px;
    height: 2px;
    margin: 4px 0;
    background: var(--color-text-primary);
    transition: background-color 300ms ease-out;
  }

  .nav-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    width: min(88vw, 280px);
    background: var(--color-surface);
    border: 1px solid var(--color-warm-gray);
    padding: 1rem;
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }

    .nav-details {
      display: none;
    }
  }
</style>
