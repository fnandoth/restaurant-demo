---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/trabaja-con-nosotros.css";
---

<BaseLayout
  title="Trabaja con nosotros · Gran Café Santander Madrid"
  description="Únete al equipo de Gran Café Santander. Envíanos tu CV y cuéntanos sobre tu experiencia en hostelería."
>
  <section class="hero hero-trabaja">
    <img
      src="/assets/restaurante-interior-camarero.jpg"
      alt="Equipo de sala del Gran Café Santander"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      class="hero-media"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 data-i18n="trabaja.heroTitle">Trabaja con nosotros</h1>
      <p data-i18n="trabaja.heroSubtitle">Queremos conocerte. Envíanos tu candidatura y tu CV.</p>
    </div>
  </section>

  <section class="careers-section">
    <div class="careers-container">
      <div class="careers-intro">
        <h2 data-i18n="trabaja.sectionTitle">Únete al equipo del Gran Café Santander</h2>
        <p data-i18n="trabaja.sectionDesc">
          Buscamos personas apasionadas por la hostelería y el servicio.
          Completa el formulario y cuéntanos tu experiencia.
        </p>
      </div>

      <form
        id="careers-form"
        class="careers-form"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="form-grid">
          <div class="form-field">
            <label for="nombre" data-i18n="trabaja.labelName">Nombre</label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              autocomplete="given-name"
              required
              aria-describedby="nombre-error"
            />
            <p class="form-error" id="nombre-error" data-error-for="nombre"></p>
          </div>

          <div class="form-field">
            <label for="apellido" data-i18n="trabaja.labelSurname">Apellido</label>
            <input
              id="apellido"
              name="apellido"
              type="text"
              autocomplete="family-name"
              required
              aria-describedby="apellido-error"
            />
            <p class="form-error" id="apellido-error" data-error-for="apellido">
            </p>
          </div>

          <div class="form-field">
            <label for="email" data-i18n="trabaja.labelEmail">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              aria-describedby="email-error"
            />
            <p class="form-error" id="email-error" data-error-for="email"></p>
          </div>

          <div class="form-field">
            <label for="telefono" data-i18n="trabaja.labelPhone">Teléfono</label>
            <input
              id="telefono"
              name="telefono"
              type="tel"
              autocomplete="tel"
              inputmode="tel"
              placeholder="+34 600 000 000"
              required
              aria-describedby="telefono-error"
            />
            <p class="form-error" id="telefono-error" data-error-for="telefono">
            </p>
          </div>

          <div class="form-field full">
            <label for="mensaje" data-i18n="trabaja.labelMessage">Mensaje / Presentación</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="6"
              required
              aria-describedby="mensaje-error"></textarea>
            <p class="form-error" id="mensaje-error" data-error-for="mensaje">
            </p>
          </div>

          <div class="form-field full">
            <label for="cv" data-i18n="trabaja.labelCV">Adjuntar CV (PDF)</label>
            <div class="file-input">
              <input
                id="cv"
                name="cv"
                type="file"
                accept=".pdf"
                required
                aria-describedby="cv-error"
              />
              <span
                id="cv-file-name"
                class="file-name"
                data-default="Ningún archivo seleccionado"
                data-i18n="trabaja.noFile"
              >
                Ningún archivo seleccionado
              </span>
            </div>
            <p class="form-error" id="cv-error" data-error-for="cv"></p>
          </div>

          <div class="form-field full form-checkbox">
            <label for="privacy">
              <input
                id="privacy"
                name="privacy"
                type="checkbox"
                required
                aria-describedby="privacy-error"
              />
              <span data-i18n="trabaja.privacy">
                He leído y acepto la
                <a
                  href="/politica-de-privacidad/"
                  target="_blank"
                  rel="noopener noreferrer"
                  data-i18n="trabaja.privacyLink"
                >
                  Política de Privacidad
                </a>
              </span>
            </label>
            <p class="form-error" id="privacy-error" data-error-for="privacy">
            </p>
          </div>
        </div>

        <div class="form-actions">
          <button class="submit-button" type="submit" data-i18n="trabaja.submit">Enviar</button>
        </div>

        <p
          class="form-success"
          id="form-success"
          role="status"
          aria-live="polite"
        >
        </p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById("careers-form");

    if (form) {
      const successMessage = document.getElementById("form-success");
      const fileInput = form.querySelector("#cv");
      const fileName = document.getElementById("cv-file-name");
      const defaultFileName =
        fileName?.dataset.default || "Ningún archivo seleccionado";

      const validators = {
        nombre: (input: { value: string }) =>
          input.value.trim() ? "" : "El nombre es obligatorio.",
        apellido: (input: { value: string }) =>
          input.value.trim() ? "" : "El apellido es obligatorio.",
        email: (input: { value: string }) => {
          const value = input.value.trim();
          if (!value) return "El email es obligatorio.";
          return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)
            ? ""
            : "Introduce un email válido.";
        },
        telefono: (input: { value: string }) => {
          const value = input.value.trim();
          if (!value) return "El teléfono es obligatorio.";
          const digits = value.replace(/\D/g, "");
          return digits.length >= 9
            ? ""
            : "Introduce un teléfono válido (mínimo 9 dígitos).";
        },
        mensaje: (input: { value: string }) =>
          input.value.trim() ? "" : "El mensaje es obligatorio.",
        cv: (input: { files: any[] }) => {
          const file = input.files && input.files[0];
          if (!file) return "Adjunta tu CV en PDF.";
          const isPdf =
            file.type === "application/pdf" ||
            file.name.toLowerCase().endsWith(".pdf");
          return isPdf ? "" : "Solo se permiten archivos PDF.";
        },
        privacy: (input: { checked: any }) =>
          input.checked ? "" : "Debes aceptar la política de privacidad.",
      };

      const setError = (input: Element, message: string | null) => {
        const error = form.querySelector(`[data-error-for="${input.id}"]`);
        if (!error) return;
        if (message) {
          input.classList.add("field-error");
          input.setAttribute("aria-invalid", "true");
          error.textContent = message;
        } else {
          input.classList.remove("field-error");
          input.setAttribute("aria-invalid", "false");
          error.textContent = "";
        }
      };

      const validateField = (input: Element) => {
        const validator = validators[input.id];
        if (!validator) return true;
        const message = validator(input);
        setError(input, message);
        return !message;
      };

      const validateAll = () => {
        let isValid = true;
        Object.keys(validators).forEach((id) => {
          const input = form.querySelector(`#${id}`);
          if (!input) return;
          if (!validateField(input)) isValid = false;
        });
        return isValid;
      };

      const updateFileName = () => {
        if (!fileName) return;
        const file = fileInput && fileInput.files && fileInput.files[0];
        fileName.textContent = file ? file.name : defaultFileName;
      };

      const clearAllErrors = () => {
        Object.keys(validators).forEach((id) => {
          const input = form.querySelector(`#${id}`);
          if (!input) return;
          setError(input, "");
        });
      };

      ["nombre", "apellido", "email", "telefono", "mensaje"].forEach((id) => {
        const input = form.querySelector(`#${id}`);
        if (!input) return;
        input.addEventListener("input", () => validateField(input));
        input.addEventListener("blur", () => validateField(input));
      });

      const privacyInput = form.querySelector("#privacy");
      if (privacyInput) {
        privacyInput.addEventListener("change", () =>
          validateField(privacyInput),
        );
      }

      if (fileInput) {
        fileInput.addEventListener("change", () => {
          updateFileName();
          validateField(fileInput);
        });
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (successMessage) successMessage.textContent = "";

        if (!validateAll()) return;

        // TODO: Se necesita configuarar segun los detalles del backend o servicio de terceros que se vaya a utilizar para procesar las solicitudes de empleo.

        if (successMessage) {
          successMessage.textContent =
            "¡Gracias por tu interés! Hemos recibido tu solicitud y nos pondremos en contacto contigo pronto.";
        }

        form.reset();
        updateFileName();
        clearAllErrors();
      });

      updateFileName();
    }
  </script>
</BaseLayout>
