---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Trabaja con nosotros · Gran Café Santander Madrid"
  description="Únete al equipo de Gran Café Santander. Envíanos tu CV y cuéntanos sobre tu experiencia en hostelería."
>
  <section class="hero hero-trabaja">
    <img
      src="/assets/restaurante-interior-camarero.jpg"
      alt="Equipo de sala del Gran Café Santander"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      class="hero-media"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Trabaja con nosotros</h1>
      <p>Queremos conocerte. Envíanos tu candidatura y tu CV.</p>
    </div>
  </section>

  <section class="careers-section">
    <div class="careers-container">
      <div class="careers-intro">
        <h2>Únete al equipo del Gran Café Santander</h2>
        <p>
          Buscamos personas apasionadas por la hostelería y el servicio. Completa el formulario y cuéntanos tu
          experiencia.
        </p>
      </div>

      <form id="careers-form" class="careers-form" novalidate enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-field">
            <label for="nombre">Nombre</label>
            <input
              id="nombre"
              name="nombre"
              type="text"
              autocomplete="given-name"
              required
              aria-describedby="nombre-error"
            />
            <p class="form-error" id="nombre-error" data-error-for="nombre"></p>
          </div>

          <div class="form-field">
            <label for="apellido">Apellido</label>
            <input
              id="apellido"
              name="apellido"
              type="text"
              autocomplete="family-name"
              required
              aria-describedby="apellido-error"
            />
            <p class="form-error" id="apellido-error" data-error-for="apellido"></p>
          </div>

          <div class="form-field">
            <label for="email">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              aria-describedby="email-error"
            />
            <p class="form-error" id="email-error" data-error-for="email"></p>
          </div>

          <div class="form-field">
            <label for="telefono">Teléfono</label>
            <input
              id="telefono"
              name="telefono"
              type="tel"
              autocomplete="tel"
              inputmode="tel"
              placeholder="+34 600 000 000"
              required
              aria-describedby="telefono-error"
            />
            <p class="form-error" id="telefono-error" data-error-for="telefono"></p>
          </div>

          <div class="form-field full">
            <label for="mensaje">Mensaje / Presentación</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="6"
              required
              aria-describedby="mensaje-error"
            ></textarea>
            <p class="form-error" id="mensaje-error" data-error-for="mensaje"></p>
          </div>

          <div class="form-field full">
            <label for="cv">Adjuntar CV (PDF)</label>
            <div class="file-input">
              <input id="cv" name="cv" type="file" accept=".pdf" required aria-describedby="cv-error" />
              <span id="cv-file-name" class="file-name" data-default="Ningún archivo seleccionado">
                Ningún archivo seleccionado
              </span>
            </div>
            <p class="form-error" id="cv-error" data-error-for="cv"></p>
          </div>

          <div class="form-field full form-checkbox">
            <label for="privacy">
              <input id="privacy" name="privacy" type="checkbox" required aria-describedby="privacy-error" />
              <span>
                He leído y acepto la
                <a href="/politica-de-privacidad/" target="_blank" rel="noopener noreferrer">
                  Política de Privacidad
                </a>
              </span>
            </label>
            <p class="form-error" id="privacy-error" data-error-for="privacy"></p>
          </div>
        </div>

        <div class="form-actions">
          <button class="submit-button" type="submit">Enviar</button>
        </div>

        <p class="form-success" id="form-success" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('careers-form');

    if (form) {
      const successMessage = document.getElementById('form-success');
      const fileInput = form.querySelector('#cv');
      const fileName = document.getElementById('cv-file-name');
      const defaultFileName = fileName?.dataset.default || 'Ningún archivo seleccionado';

      const validators = {
        nombre: (input: { value: string; }) => (input.value.trim() ? '' : 'El nombre es obligatorio.'),
        apellido: (input: { value: string; }) => (input.value.trim() ? '' : 'El apellido es obligatorio.'),
        email: (input: { value: string; }) => {
          const value = input.value.trim();
          if (!value) return 'El email es obligatorio.';
          return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value) ? '' : 'Introduce un email válido.';
        },
        telefono: (input: { value: string; }) => {
          const value = input.value.trim();
          if (!value) return 'El teléfono es obligatorio.';
          const digits = value.replace(/\D/g, '');
          return digits.length >= 9 ? '' : 'Introduce un teléfono válido (mínimo 9 dígitos).';
        },
        mensaje: (input: { value: string; }) => (input.value.trim() ? '' : 'El mensaje es obligatorio.'),
        cv: (input: { files: any[]; }) => {
          const file = input.files && input.files[0];
          if (!file) return 'Adjunta tu CV en PDF.';
          const isPdf = file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf');
          return isPdf ? '' : 'Solo se permiten archivos PDF.';
        },
        privacy: (input: { checked: any; }) => (input.checked ? '' : 'Debes aceptar la política de privacidad.')
      };

      const setError = (input: Element, message: string | null) => {
        const error = form.querySelector(`[data-error-for="${input.id}"]`);
        if (!error) return;
        if (message) {
          input.classList.add('field-error');
          input.setAttribute('aria-invalid', 'true');
          error.textContent = message;
        } else {
          input.classList.remove('field-error');
          input.setAttribute('aria-invalid', 'false');
          error.textContent = '';
        }
      };

      const validateField = (input: Element) => {
        const validator = validators[input.id];
        if (!validator) return true;
        const message = validator(input);
        setError(input, message);
        return !message;
      };

      const validateAll = () => {
        let isValid = true;
        Object.keys(validators).forEach((id) => {
          const input = form.querySelector(`#${id}`);
          if (!input) return;
          if (!validateField(input)) isValid = false;
        });
        return isValid;
      };

      const updateFileName = () => {
        if (!fileName) return;
        const file = fileInput && fileInput.files && fileInput.files[0];
        fileName.textContent = file ? file.name : defaultFileName;
      };

      const clearAllErrors = () => {
        Object.keys(validators).forEach((id) => {
          const input = form.querySelector(`#${id}`);
          if (!input) return;
          setError(input, '');
        });
      };

      ['nombre', 'apellido', 'email', 'telefono', 'mensaje'].forEach((id) => {
        const input = form.querySelector(`#${id}`);
        if (!input) return;
        input.addEventListener('input', () => validateField(input));
        input.addEventListener('blur', () => validateField(input));
      });

      const privacyInput = form.querySelector('#privacy');
      if (privacyInput) {
        privacyInput.addEventListener('change', () => validateField(privacyInput));
      }

      if (fileInput) {
        fileInput.addEventListener('change', () => {
          updateFileName();
          validateField(fileInput);
        });
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (successMessage) successMessage.textContent = '';

        if (!validateAll()) return;

        // TODO: Se necesita configuarar segun los detalles del backend o servicio de terceros que se vaya a utilizar para procesar las solicitudes de empleo.

        if (successMessage) {
          successMessage.textContent =
            '¡Gracias por tu interés! Hemos recibido tu solicitud y nos pondremos en contacto contigo pronto.';
        }

        form.reset();
        updateFileName();
        clearAllErrors();
      });

      updateFileName();
    }
  </script>

  <style>
    .hero {
      position: relative;
      height: 300px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: var(--color-surface);
      overflow: hidden;
    }

    .hero-media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: rgba(28, 20, 16, 0.5);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      padding: 0 1.5rem;
    }

    .hero-content h1 {
      font-family: var(--font-display);
      font-size: 2.6rem;
      margin-bottom: 0.5rem;
    }

    .hero-content p {
      font-family: var(--font-body);
      font-size: 1rem;
      opacity: 0.9;
    }

    .careers-section {
      background: var(--color-cream);
      padding: var(--section-padding-y) 0;
    }

    .careers-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .careers-intro h2 {
      font-family: var(--font-display);
      font-size: 2.1rem;
      margin-bottom: 0.75rem;
    }

    .careers-intro p {
      color: var(--color-text-muted);
      font-size: 1rem;
      line-height: 1.6;
      margin: 0;
    }

    .careers-form {
      background: var(--color-surface);
      border: 1px solid var(--color-warm-gray);
      border-radius: 4px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .form-grid {
      display: grid;
      gap: 1.25rem;
    }

    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-field label {
      font-family: var(--font-body);
      font-weight: 600;
      color: var(--color-text-primary);
    }

    .form-field input,
    .form-field textarea {
      width: 100%;
      padding: 0.75rem 0.9rem;
      border-radius: 4px;
      border: 1px solid var(--color-warm-gray);
      background: var(--color-surface);
      font-family: var(--font-body);
      color: var(--color-text-primary);
      transition: border-color 200ms ease, box-shadow 200ms ease;
    }


    #privacy {
      width: auto;
      margin-top: 0.2rem;
    }

    .form-field textarea {
      min-height: 160px;
      resize: vertical;
    }

    .form-field input:focus,
    .form-field textarea:focus {
      border-color: var(--color-brand);
      box-shadow: 0 0 0 2px rgba(139, 99, 71, 0.15);
      outline: none;
    }

    .field-error {
      border-color: var(--color-warning);
      box-shadow: 0 0 0 2px rgba(176, 122, 26, 0.15);
    }

    .form-checkbox input.field-error {
      outline: 2px solid var(--color-warning);
      outline-offset: 2px;
    }

    .form-error {
      color: var(--color-warning);
      font-size: 0.85rem;
      margin: 0;
    }

    .form-error:empty {
      display: none;
    }

    .file-input {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .file-name {
      font-size: 0.85rem;
      color: var(--color-text-muted);
    }

    .form-checkbox label {
      display: flex;
      gap: 0.6rem;
      align-items: flex-start;
      font-size: 0.95rem;
      color: var(--color-text-primary);
    }

    .form-checkbox a {
      color: var(--color-brand);
      text-decoration: none;
      font-weight: 600;
    }

    .form-checkbox a:hover {
      color: var(--color-brand-dark);
    }

    .form-actions {
      display: flex;
      justify-content: flex-start;
    }

    .submit-button {
      border: none;
      background: var(--color-brand);
      color: var(--color-surface);
      padding: 0.85rem 2.2rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 0.85rem;
      cursor: pointer;
      transition: background-color 200ms ease, transform 200ms ease;
    }

    .submit-button:hover {
      background: var(--color-brand-dark);
      transform: translateY(-1px);
    }

    .form-success {
      margin: 0;
      padding: 1rem 1.25rem;
      border-left: 4px solid var(--color-success);
      background: rgba(45, 106, 79, 0.12);
      color: var(--color-success);
      font-weight: 600;
    }

    .form-success:empty {
      display: none;
    }

    @media (min-width: 768px) {
      .hero {
        height: 340px;
      }

      .form-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .form-field.full {
        grid-column: 1 / -1;
      }
    }
  </style>
</BaseLayout>
