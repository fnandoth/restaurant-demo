---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import menuEs from '../data/menu.es.json';
import menuEn from '../data/menu.en.json';
import desayunoEs from '../data/desayuno.es.json';
import desayunoEn from '../data/desayuno.en.json';
import heroImage from '../assets/hero/restaurante-interior-clientes-patio.jpg';
import "../styles/carta.css";
// Eliminamos la lectura de cookies del servidor, ya que delegaremos el intercambio
// de idioma al cliente mediante atributos de datos (data-es, data-en)
const menuCategoriesEs = menuEs.menu;
const menuCategoriesEn = menuEn.menu;
const desayunoCategoriesEs = desayunoEs.menu;
const desayunoCategoriesEn = desayunoEn.menu;

const heroOptimized = await getImage({
  src: heroImage,
  widths: [480, 768, 1024, 1280, 1600],
  format: 'webp',
  quality: 70,
  sizes: '100vw'
});
const heroPreloadSrc = heroOptimized.src;

const menuImageModules = import.meta.glob('../assets/menu/*.jpg', { eager: true });
const menuImages = Object.fromEntries(
  Object.entries(menuImageModules).flatMap(([path, module]) => {
    const fileName = path.split('/').pop();
    return fileName ? [[fileName, module.default]] : [];
  })
);

const slugify = (value: string) =>
  `cat-${value
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')}`;

const imageMap = [
