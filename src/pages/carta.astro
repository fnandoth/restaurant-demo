const getDishAsset = (name: string) =>
  imageMap.find((entry) => name.toLowerCase().includes(entry.match.toLowerCase())) ?? null;

const getCeliacBadge = (status: string) => {
  if (!status) return null;
  if (status === 'Apto para celíacos') {
    return { text: status, className: 'celiac-badge celiac-good' };
  }
  if (status === 'Previa modificación, apto para celíacos') {
    return { text: status, className: 'celiac-badge celiac-warn' };
  }
  return null;
};

const menuSchema = {
  '@context': 'https://schema.org',
  '@type': 'Menu',
  name: 'Carta Gran Café Santander',
  url: 'https://grancafesantander.es/carta',
  inLanguage: 'es',
  hasMenuSection: [
    { '@type': 'MenuSection', name: 'Entrantes fríos' },
    { '@type': 'MenuSection', name: 'Entrantes calientes' },
    { '@type': 'MenuSection', name: 'Pescados' },
    { '@type': 'MenuSection', name: 'Carnes' },
    { '@type': 'MenuSection', name: 'Postres' }
  ]
};
---

<BaseLayout
  title="Carta y Menú · Gran Café Santander Madrid"
  description="Consulta la carta completa de Gran Café Santander en Madrid: entrantes, pescados, carnes, arroces, postres y desayunos. Información de alérgenos incluida."
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify(menuSchema)}</script>
  </Fragment>
  <section
    id="hero-carta"
    class="relative flex items-center justify-center text-center"
    style="height: 320px;"
  >
    <img
      src="/assets/restaurante-interior-clientes-patio.jpg"
      alt="Clientes en el patio interior del restaurante"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0" style="background: rgba(28, 20, 16, 0.55);"></div>
    <div class="relative z-10 px-6">
      <h1 class="text-4xl text-white md:text-5xl" style="font-family: var(--font-display);">
        Nuestra Carta
      </h1>
      <p class="mt-3 text-base text-white/85">
        Cocina tradicional con producto de temporada
      </p>
    </div>
  </section>

  <div class="tab-bar" role="tablist" aria-label="Secciones de la carta">
    <button
      id="tab-carta"
      class="tab-button is-active"
      data-target="carta-principal"
      data-hash="carta"
      role="tab"
      aria-selected="true"
      aria-controls="carta-principal"
      tabindex="0"
    >
      Carta Principal
    </button>
    <button
      id="tab-desayunos"
      class="tab-button"
      data-target="desayunos"
      data-hash="desayunos"
      role="tab"
      aria-selected="false"
      aria-controls="desayunos"
      tabindex="-1"
    >
      Desayunos &amp; Meriendas
    </button>
  </div>

  <div
    class="tab-panel is-active"
    id="carta-principal"
    role="tabpanel"
    aria-labelledby="tab-carta"
    aria-hidden="false"
    tabindex="0"
  >
    <div class="menu-layout">
      <aside class="menu-sidebar">
        <p class="sidebar-title">Carta principal</p>
        <nav class="sidebar-links">
          {menuCategories.map((category) => (
            <a href={`#${slugify(category.categoria)}`} data-anchor={slugify(category.categoria)}>
              {category.categoria}
            </a>
          ))}
        </nav>
      </aside>

      <div class="menu-content">
        {menuCategories.map((category) => (
          <section class="menu-category" id={slugify(category.categoria)}>
            <div class="category-header">
              <span class="category-line"></span>
              <h2>{category.categoria}</h2>
              <span class="category-line"></span>
            </div>
            <div class="menu-list">
              {category.platos.map((dish) => {
                const asset = getDishAsset(dish.nombre);
                const badge = getCeliacBadge(dish.apto_celiacos);
                return (
                  <div class="menu-item">
                    <div class="menu-item-main">
                      {asset ? (
                        <img
                          src={asset.src}
                          alt={asset.alt}
                          width="56"
                          height="56"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : null}
                      <div class="menu-item-text">
                        <div class="menu-item-title">
                          <span>{dish.nombre}</span>
                          <span class="menu-price">{dish.precio}</span>
                        </div>
                        {dish.alergenos ? (
                          <p class="menu-allergens">{dish.alergenos}</p>
                        ) : null}
                        {badge ? <span class={badge.className}>{badge.text}</span> : null}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    </div>
  </div>

  <div
    class="tab-panel"
    id="desayunos"
    role="tabpanel"
    aria-labelledby="tab-desayunos"
    aria-hidden="true"
    tabindex="0"
  >
    <div class="menu-layout">
      <aside class="menu-sidebar">
        <p class="sidebar-title">Desayunos</p>
        <nav class="sidebar-links">
          {desayunoCategories.map((category) => (
            <a href={`#${slugify(category.categoria)}`} data-anchor={slugify(category.categoria)}>
              {category.categoria.replace(/\s*\(.*\)/, '')}
            </a>
          ))}
        </nav>
      </aside>

      <div class="menu-content">
        {desayunoCategories.map((category) => (
          <section class="menu-category" id={slugify(category.categoria)}>
            <div class="category-header">
              <span class="category-line"></span>
              <h2>{category.categoria.replace(/\s*\(.*\)/, '')}</h2>
              <span class="category-line"></span>
            </div>
            {category.categoria.includes('Desayuno Gran Café Santander') ? (
              <p class="menu-note">
                Café o infusión incluido con su acompañamiento a elegir
              </p>
            ) : null}
            <div class="menu-list">
              {category.platos.map((dish) => {
                const asset = getDishAsset(dish.nombre);
                const badge = getCeliacBadge(dish.apto_celiacos);
                return (
                  <div class="menu-item">
                    <div class="menu-item-main">
                      {asset ? (
                        <img
                          src={asset.src}
                          alt={asset.alt}
                          width="56"
                          height="56"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : null}
                      <div class="menu-item-text">
                        <div class="menu-item-title">
                          <span>{dish.nombre}</span>
                          <span class="menu-price">{dish.precio}</span>
                        </div>
                        {dish.alergenos ? (
                          <p class="menu-allergens">{dish.alergenos}</p>
                        ) : null}
                        {badge ? <span class={badge.className}>{badge.text}</span> : null}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    </div>
  </div>

  <div class="allergen-note">
    <span class="note-icon">⚠</span>
    <p>
      Información sobre alérgenos disponible bajo petición al personal del restaurante.
      Algunos platos pueden modificarse para adaptarse a necesidades dietéticas específicas.
    </p>
  </div>

  <script>
    const tabs = document.querySelectorAll('.tab-button');
    const panels = document.querySelectorAll('.tab-panel');
    const setActiveTab = (targetId) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.target === targetId;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
      });
      panels.forEach((panel) => {
        const isActive = panel.id === targetId;
        panel.classList.toggle('is-active', isActive);
        panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    };
    const updateHash = (hash) => {
      if (hash) window.location.hash = hash;
    };
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        setActiveTab(tab.dataset.target);
        updateHash(tab.dataset.hash === 'desayunos' ? '#desayunos' : '#carta');
      });
    });
    const initialHash = window.location.hash.replace('#', '');
    if (initialHash === 'desayunos') {
      setActiveTab('desayunos');
    } else {
      setActiveTab('carta-principal');
    }

    const observerOptions = {
      rootMargin: '-30% 0px -60% 0px',
      threshold: 0
    };
    const observePanels = (panelId) => {
      const panel = document.getElementById(panelId);
      if (!panel) return;
      const links = panel.querySelectorAll('.sidebar-links a');
      const sections = panel.querySelectorAll('.menu-category');
      const map = new Map();
      links.forEach((link) => {
        map.set(link.getAttribute('data-anchor'), link);
      });
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            links.forEach((link) => link.classList.toggle('is-active', link.dataset.anchor === id));
          }
        });
      }, observerOptions);
      sections.forEach((section) => observer.observe(section));
    };
    observePanels('carta-principal');
    observePanels('desayunos');
  </script>

  <style>
    .tab-bar {
      position: sticky;
      top: var(--nav-height);
      z-index: 40;
      display: flex;
      justify-content: center;
      gap: 2rem;
      padding: 1rem 1.5rem;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-warm-gray);
    }

    .tab-button {
      font-family: var(--font-body);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--color-text-muted);
      padding-bottom: 0.5rem;
      border: none;
      background: transparent;
      cursor: pointer;
      border-bottom: 3px solid transparent;
      transition: color 300ms ease-out, border-color 300ms ease-out;
    }

    .tab-button.is-active {
      color: var(--color-brand-dark);
      border-bottom-color: var(--color-brand);
      font-weight: 700;
    }

    .tab-button:hover {
      color: var(--color-brand-dark);
    }

    .tab-panel {
      display: none;
      background: var(--color-surface);
    }

    .tab-panel.is-active {
      display: block;
    }

    .menu-layout {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 3rem 1.5rem;
      display: grid;
      gap: 3rem;
    }

    .menu-sidebar {
      display: none;
      position: sticky;
      top: calc(var(--nav-height) + 3rem);
      align-self: start;
    }

    .sidebar-title {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      margin-bottom: 1rem;
      color: var(--color-text-muted);
    }

    .sidebar-links {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      font-size: 0.85rem;
      color: var(--color-text-muted);
    }

    .sidebar-links a {
      color: inherit;
      text-decoration: none;
      transition: color 300ms ease-out;
    }

    .sidebar-links a:hover,
    .sidebar-links a.is-active {
      color: var(--color-brand);
    }

    .menu-content {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .menu-category h2 {
      font-family: var(--font-display);
      font-style: italic;
      font-weight: 600;
      font-size: 22px;
      margin: 0;
      color: var(--color-text-primary);
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .category-line {
      flex: 1;
      height: 1px;
      background: var(--color-warm-gray);
    }

    .menu-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .menu-item {
      border-bottom: 1px solid var(--color-warm-gray);
      padding-bottom: 1rem;
    }

    .menu-item-main {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .menu-item img {
      width: 56px;
      height: 56px;
      object-fit: cover;
      border-radius: 4px;
    }

    .menu-item-text {
      flex: 1;
    }

    .menu-item-title {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 16px;
      color: var(--color-text-primary);
    }

    .menu-price {
      color: var(--color-brand);
      font-weight: 400;
      white-space: nowrap;
    }

    .menu-allergens {
      font-size: 12px;
      font-weight: 300;
      margin-top: 0.35rem;
      color: var(--color-text-muted);
    }

    .celiac-badge {
      display: inline-block;
      margin-top: 0.35rem;
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      color: var(--color-surface);
    }

    .celiac-good {
      background: var(--color-success);
    }

    .celiac-warn {
      background: var(--color-warning);
    }

    .menu-note {
      margin: -0.5rem 0 1.25rem;
      font-size: 0.95rem;
      color: var(--color-text-muted);
      font-style: italic;
    }

