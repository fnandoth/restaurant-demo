const getDishAsset = (name: string) => {
  const entry = imageMap.find((item) => name.toLowerCase().includes(item.match.toLowerCase()));
  if (!entry) return null;
  const src = menuImages[entry.file];
  if (src) return { src, alt: entry.alt, optimized: true };
  return { src: `/assets/${entry.file}`, alt: entry.alt, optimized: false };
};

const getCeliacBadge = (statusEs: string, statusEn?: string) => {
  if (!statusEs) return null;
  if (statusEs === 'Apto para celíacos') {
    return { es: statusEs, en: statusEn || 'Gluten-free', className: 'celiac-badge celiac-good' };
  }
  if (statusEs === 'Previa modificación, apto para celíacos') {
    return { es: statusEs, en: statusEn || 'Gluten-free upon request', className: 'celiac-badge celiac-warn' };
  }
  return null;
};

const menuSchema = {
  '@context': 'https://schema.org',
  '@type': 'Menu',
  name: 'Carta Gran Café Santander',
  url: 'https://grancafesantander.es/carta',
  inLanguage: 'es',
  hasMenuSection: [
    { '@type': 'MenuSection', name: 'Entrantes fríos' },
    { '@type': 'MenuSection', name: 'Entrantes calientes' },
    { '@type': 'MenuSection', name: 'Pescados' },
    { '@type': 'MenuSection', name: 'Carnes' },
    { '@type': 'MenuSection', name: 'Postres' }
  ]
};
---

<BaseLayout
  title="Carta y Menú · Gran Café Santander Madrid"
  description="Consulta la carta completa de Gran Café Santander en Madrid: entrantes, pescados, carnes, arroces, postres y desayunos. Información de alérgenos incluida."
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroPreloadSrc} imagesizes="100vw" />
    <script type="application/ld+json">{JSON.stringify(menuSchema)}</script>
  </Fragment>

  <section
    id="hero-carta"
    class="relative flex items-center justify-center text-center"
    style="height: 320px;"
  >
    <Image
      src={heroImage}
      widths={[480, 768, 1024, 1280, 1600]}
      sizes="100vw"
      width={1600}
      height={900}
      format="webp"
      quality={70}
      alt="Clientes en el patio interior del restaurante"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0" style="background: rgba(28, 20, 16, 0.55);"></div>
    <div class="relative z-10 px-6">
      <h1 class="text-4xl text-white md:text-5xl" style="font-family: var(--font-display);" data-es="Nuestra Carta" data-en="Our Menu">
        Nuestra Carta
      </h1>
      <p class="mt-3 text-base text-white/85" data-es="Cocina tradicional con producto de temporada" data-en="Traditional cuisine with seasonal products">
        Cocina tradicional con producto de temporada
      </p>
    </div>
  </section>

  <div class="tab-bar" role="tablist" aria-label="Secciones de la carta">
    <button
      id="tab-carta"
      class="tab-button is-active"
      data-target="carta-principal"
      data-hash="carta"
      role="tab"
      aria-selected="true"
      aria-controls="carta-principal"
      tabindex="0"
      data-es="Carta Principal"
      data-en="Main Menu"
    >
      Carta Principal
    </button>
    <button
      id="tab-desayunos"
      class="tab-button"
      data-target="desayunos"
      data-hash="desayunos"
      role="tab"
      aria-selected="false"
      aria-controls="desayunos"
      tabindex="-1"
      data-es="Desayunos &amp; Meriendas"
      data-en="Breakfast &amp; Snacks"
    >
      Desayunos &amp; Meriendas
    </button>
  </div>

  <div
    class="tab-panel is-active"
    id="carta-principal"
    role="tabpanel"
    aria-labelledby="tab-carta"
    aria-hidden="false"
    tabindex="0"
  >
    <div class="menu-layout">
      <aside class="menu-sidebar">
        <p class="sidebar-title" data-es="Carta principal" data-en="Main menu">Carta principal</p>
        <nav class="sidebar-links">
          {menuCategoriesEs.map((category, index) => {
            const catEn = menuCategoriesEn[index] || category;
            return (
              <a href={`#${slugify(category.categoria)}`} data-anchor={slugify(category.categoria)} data-es={category.categoria} data-en={catEn.categoria}>
                {category.categoria}
              </a>
            );
          })}
        </nav>
      </aside>

      <div class="menu-content">
        {menuCategoriesEs.map((category, catIndex) => {
          const catEn = menuCategoriesEn[catIndex] || category;
          return (
            <section class="menu-category" id={slugify(category.categoria)}>
              <div class="category-header">
                <span class="category-line"></span>
                <h2 data-es={category.categoria} data-en={catEn.categoria}>{category.categoria}</h2>
                <span class="category-line"></span>
              </div>
              <div class="menu-list">
                {category.platos.map((dish, dishIndex) => {
                  const dishEn = catEn.platos?.[dishIndex] || dish;
                  const asset = getDishAsset(dish.nombre);
                  const badge = getCeliacBadge(dish.apto_celiacos, dishEn?.apto_celiacos);
                  return (
                    <div class="menu-item">
                      <div class="menu-item-main">
                        {asset ? (
                          asset.optimized ? (
                            <Image src={asset.src} alt={asset.alt} width={56} height={56} sizes="56px" format="webp" quality={60} loading="lazy" decoding="async" />
                          ) : (
                            <img src={asset.src} alt={asset.alt} width="56" height="56" loading="lazy" decoding="async" />
                          )
                        ) : null}
                        <div class="menu-item-text">
                          <div class="menu-item-title">
                            <span data-es={dish.nombre} data-en={dishEn.nombre}>{dish.nombre}</span>
                            <span class="menu-price">{dish.precio}</span>
                          </div>
                          {dish.alergenos ? (
                            <p class="menu-allergens" data-es={dish.alergenos} data-en={dishEn.alergenos || dish.alergenos}>{dish.alergenos}</p>
                          ) : null}
                          {badge ? <span class={badge.className} data-es={badge.es} data-en={badge.en}>{badge.es}</span> : null}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </div>

  <div
    class="tab-panel"
    id="desayunos"
    role="tabpanel"
    aria-labelledby="tab-desayunos"
    aria-hidden="true"
    tabindex="0"
  >
    <div class="menu-layout">
      <aside class="menu-sidebar">
        <p class="sidebar-title" data-es="Desayunos" data-en="Breakfasts">Desayunos</p>
        <nav class="sidebar-links">
          {desayunoCategoriesEs.map((category, index) => {
            const catEn = desayunoCategoriesEn[index] || category;
            return (
              <a href={`#${slugify(category.categoria)}`} data-anchor={slugify(category.categoria)} data-es={category.categoria.replace(/\s*\(.*\)/, '')} data-en={catEn.categoria.replace(/\s*\(.*\)/, '')}>
                {category.categoria.replace(/\s*\(.*\)/, '')}
              </a>
            );
          })}
        </nav>
      </aside>

      <div class="menu-content">
        {desayunoCategoriesEs.map((category, catIndex) => {
          const catEn = desayunoCategoriesEn[catIndex] || category;
          return (
            <section class="menu-category" id={slugify(category.categoria)}>
              <div class="category-header">
                <span class="category-line"></span>
                <h2 data-es={category.categoria.replace(/\s*\(.*\)/, '')} data-en={catEn.categoria.replace(/\s*\(.*\)/, '')}>
                  {category.categoria.replace(/\s*\(.*\)/, '')}
                </h2>
                <span class="category-line"></span>
              </div>
              {category.categoria.includes('Desayuno Gran Café Santander') ? (
                <p class="menu-note" data-es="Café o infusión incluido con su acompañamiento a elegir" data-en="Coffee or tea included with your choice of side">
                  Café o infusión incluido con su acompañamiento a elegir
                </p>
              ) : null}
              <div class="menu-list">
                {category.platos.map((dish, dishIndex) => {
                  const dishEn = catEn.platos?.[dishIndex] || dish;
                  const asset = getDishAsset(dish.nombre);
                  const badge = getCeliacBadge(dish.apto_celiacos, dishEn?.apto_celiacos);
                  return (
                    <div class="menu-item">
                      <div class="menu-item-main">
                        {asset ? (
                          asset.optimized ? (
                            <Image src={asset.src} alt={asset.alt} width={56} height={56} sizes="56px" format="webp" quality={60} loading="lazy" decoding="async" />
                          ) : (
                            <img src={asset.src} alt={asset.alt} width="56" height="56" loading="lazy" decoding="async" />
                          )
                        ) : null}
                        <div class="menu-item-text">
                          <div class="menu-item-title">
                            <span data-es={dish.nombre} data-en={dishEn.nombre}>{dish.nombre}</span>
                            <span class="menu-price">{dish.precio}</span>
                          </div>
                          {dish.alergenos ? (
                            <p class="menu-allergens" data-es={dish.alergenos} data-en={dishEn.alergenos || dish.alergenos}>{dish.alergenos}</p>
                          ) : null}
                          {badge ? <span class={badge.className} data-es={badge.es} data-en={badge.en}>{badge.es}</span> : null}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </div>

  <div class="allergen-note">
    <span class="note-icon">⚠</span>
    <p data-es="Información sobre alérgenos disponible bajo petición al personal del restaurante. Algunos platos pueden modificarse para adaptarse a necesidades dietéticas específicas." data-en="Allergen information available upon request to restaurant staff. Some dishes can be modified to suit specific dietary needs.">
      Información sobre alérgenos disponible bajo petición al personal del restaurante.
      Algunos platos pueden modificarse para adaptarse a necesidades dietéticas específicas.
    </p>
  </div>

  <script>
    // --- LÓGICA DE IDIOMA PARA ASTRO (CLIENT-SIDE) ---
    const updateMenuLang = (lang: string) => {
      document.querySelectorAll('[data-es][data-en]').forEach((el) => {
        const text = el.getAttribute(`data-${lang}`);
        if (text) el.textContent = text;
      });
    };

    // Aplicar en la carga inicial leyendo el estado real del cliente
    const currentLang = localStorage.getItem('gcs_lang') || 'es';
    if (currentLang !== 'es') {
      updateMenuLang(currentLang);
    }

    // Escuchar cambios sin afectar al script del Navbar que recarga la página
    window.addEventListener('langchange', (e: Event) => {
      const customEvent = e as CustomEvent;
      if (customEvent.detail && customEvent.detail.lang) {
        updateMenuLang(customEvent.detail.lang);
      }
    });

    // --- LÓGICA EXISTENTE DE TABS Y SCROLL ---
    const tabs = document.querySelectorAll('.tab-button');
    const panels = document.querySelectorAll('.tab-panel');
    const setActiveTab = (targetId: string) => {
      tabs.forEach((tab) => {
        const target = tab as HTMLElement;
        const isActive = target.dataset.target === targetId;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
      });
      panels.forEach((panel) => {
        const isActive = panel.id === targetId;
        panel.classList.toggle('is-active', isActive);
        panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    };
    
    const updateHash = (hash: string) => {
      if (hash) window.location.hash = hash;
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab as HTMLElement;
        setActiveTab(target.dataset.target as string);
        updateHash(target.dataset.hash === 'desayunos' ? '#desayunos' : '#carta');
      });
    });

    const initialHash = window.location.hash.replace('#', '');
    if (initialHash === 'desayunos') {
      setActiveTab('desayunos');
    } else {
      setActiveTab('carta-principal');
    }

    const observerOptions = {
      rootMargin: '-30% 0px -60% 0px',
      threshold: 0
    };

    const observePanels = (panelId: string) => {
      const panel = document.getElementById(panelId);
      if (!panel) return;
      const links = panel.querySelectorAll('.sidebar-links a');
      const sections = panel.querySelectorAll('.menu-category');
      const map = new Map();
      
      links.forEach((link) => {
        const el = link as HTMLElement;
        map.set(el.getAttribute('data-anchor'), link);
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            links.forEach((link) => {
              const el = link as HTMLElement;
              el.classList.toggle('is-active', el.dataset.anchor === id);
            });
          }
        });
      }, observerOptions);

      sections.forEach((section) => observer.observe(section));
    };

    observePanels('carta-principal');
    observePanels('desayunos');
  </script>
</BaseLayout>