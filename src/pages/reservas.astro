---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reservas · Gran Café Santander Madrid"
  description="Reserva mesa en Gran Café Santander, Madrid. Cocina cantabresa de calidad en Plaza de Santa Bárbara. Reservas online o al 914 457 295 en horario de cocina."
>
  <section class="hero hero-reservas">
    <img
      src="/assets/restaurante-interior-dos-clientes.jpg"
      alt="Ambiente íntimo en Gran Café Santander Madrid"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      class="hero-media"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Reserva tu mesa</h1>
      <p>Asegura tu lugar en Gran Café Santander</p>
    </div>
  </section>

  <section class="reservas-section">
    <div class="reservas-container">
      <h2>Selecciona fecha y hora</h2>

      <!-- COVERMANAGER WIDGET — PENDING CONFIGURATION -->
      <div
        id="covermanager-widget"
        data-restaurant="PENDING"
        style="min-height: 480px; display: flex; align-items: center; justify-content: center; border: 1px dashed var(--color-warm-gray); border-radius: 4px;"
      >
        <p style="color: var(--color-text-muted); font-family: var(--font-body); font-size: 14px; text-align: center;">
          Widget de reservas — pendiente de configuración.<br />
          Visita <a href="https://www.covermanager.com" target="_blank" rel="noopener">covermanager.com</a> para completar la integración.
        </p>
      </div>
      <!-- END COVERMANAGER -->

      <!--
        COVERMANAGER INTEGRATION INSTRUCTIONS:
        1. Log in at https://www.covermanager.com
        2. Go to Settings > Widget > Embed Code
        3. Replace the div above with the provided <script> tag
        4. Remove this comment block
      -->

      <div class="reservas-fallback">
        <span class="divider"></span>
        <p class="fallback-title">¿Prefieres llamarnos?</p>
        <a href="tel:+34914457295" class="fallback-phone">914 457 295</a>
        <p class="fallback-note">Atención telefónica en horario de cocina</p>
      </div>

      <div class="hours-card">
        <h3>Horario de cocina</h3>
        <div class="hours-grid">
          <div>
            <p class="hours-label">Lun–Jue</p>
            <p>13:00–16:00 / 20:00–23:00</p>
          </div>
          <div>
            <p class="hours-label">Vie–Sáb</p>
            <p>13:00–16:30 / 20:00–23:30</p>
          </div>
          <div>
            <p class="hours-label">Dom</p>
            <p>13:00–16:30 / 20:00–23:00</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero {
      position: relative;
      height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: var(--color-surface);
      overflow: hidden;
    }

    .hero-media {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: rgba(28, 20, 16, 0.5);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      padding: 0 1.5rem;
    }

    .hero-content h1 {
      font-family: var(--font-display);
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }

    .hero-content p {
      font-family: var(--font-body);
      font-size: 1rem;
      opacity: 0.85;
    }

    .reservas-section {
      background: var(--color-cream);
      padding: var(--section-padding-y) 0;
    }

    .reservas-container {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .reservas-container a {
      transition: color 300ms ease-out;
    }

    .reservas-container a:hover {
      color: var(--color-brand-dark);
    }

    .reservas-container h2 {
      font-family: var(--font-display);
      font-size: 2rem;
      text-align: center;
      color: var(--color-text-primary);
    }

    .reservas-fallback {
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      align-items: center;
    }

    .divider {
      width: 100%;
      height: 1px;
      background: var(--color-warm-gray);
      margin-bottom: 1rem;
    }

    .fallback-title {
      font-family: var(--font-body);
      color: var(--color-text-primary);
      font-size: 1rem;
    }

    .fallback-phone {
      font-family: var(--font-display);
      font-size: 1.6rem;
      color: var(--color-brand);
      text-decoration: none;
      transition: color 300ms ease-out;
    }

    .fallback-phone:hover {
      color: var(--color-brand-dark);
    }

    .fallback-note {
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--color-text-muted);
    }

    .hours-card {
      background: var(--color-surface-alt);
      border-left: 3px solid var(--color-brand);
      padding: 1.5rem;
      border-radius: 4px;
      font-family: var(--font-body);
      color: var(--color-text-primary);
    }

    .hours-card h3 {
      font-family: var(--font-display);
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }

    .hours-grid {
      display: grid;
      gap: 1rem;
    }

    .hours-label {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--color-text-muted);
      margin-bottom: 0.25rem;
    }

    @media (min-width: 640px) {
      .hours-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</BaseLayout>
