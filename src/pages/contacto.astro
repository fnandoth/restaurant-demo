---
import BaseLayout from '../layouts/BaseLayout.astro';
import "../styles/contacto.css";
---

<BaseLayout
  title="Contacto y Cómo Llegar · Gran Café Santander Madrid"
  description="Gran Café Santander · Plaza de Santa Bárbara, 4 · 28004 Madrid · Tel. 914 457 295. Horarios, mapa y cómo llegar en metro o bus desde el centro de Madrid."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'LocalBusiness',
        name: 'Gran Café Santander',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Plaza de Santa Bárbara, 4',
          addressLocality: 'Madrid',
          postalCode: '28004',
          addressCountry: 'ES'
        },
        telephone: '+34914457295',
        hasMap: 'https://maps.google.com/?q=Plaza+de+Santa+Bárbara+4+Madrid'
      })}
    </script>
  </Fragment>
  <section class="hero hero-contacto">
    <img
      src="/assets/restaurante-afuera-patio.jpg"
      alt="Terraza exterior del Gran Café Santander"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      class="hero-media"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 data-i18n="contacto.heroTitle">Encuéntranos</h1>
      <p>Plaza de Santa Bárbara · Madrid</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="contact-grid">
      <div class="contact-info">
        <h2 data-i18n="contacto.sectionTitle">Contacto y ubicación</h2>

        <div class="info-item">
          <span class="info-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M12 21s7-7.5 7-12a7 7 0 1 0-14 0c0 4.5 7 12 7 12z" />
              <circle cx="12" cy="9" r="2.5" />
            </svg>
          </span>
          <div>
            <p class="info-title" data-i18n="contacto.addressLabel">Dirección</p>
            <p>Plaza de Santa Bárbara, 4</p>
            <p>28004 Madrid</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M4 5.5c4.5 7.5 7 10 14 14l2-2c1-1 1-2.5 0-3.5l-2.5-2c-0.8-0.6-1.9-0.5-2.6 0.2l-0.9 0.9c-2-1.3-3.7-3-5-5l0.9-0.9c0.7-0.7 0.8-1.8 0.2-2.6L7.5 2c-1-1-2.5-1-3.5 0l-2 2z" />
            </svg>
          </span>
          <div>
            <p class="info-title" data-i18n="contacto.phoneLabel">Teléfono</p>
            <a href="tel:+34914457295">914 457 295</a>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="12" cy="12" r="8" />
              <path d="M12 7v5l3 2" />
            </svg>
          </span>
          <div>
            <p class="info-title" data-i18n="contacto.hoursLabel">Horario del local</p>
            <p data-i18n="contacto.hoursLine1">Lunes – Viernes: 08:00 – 01:00</p>
            <p data-i18n="contacto.hoursLine2">Sábado, Domingo y Festivo: 09:00 – 01:00</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M6 3v7a3 3 0 0 0 6 0V3" />
              <path d="M6 14v7" />
              <path d="M12 14v7" />
              <path d="M14 4h4" />
              <path d="M16 4v16" />
            </svg>
          </span>
          <div>
            <p class="info-title" data-i18n="contacto.kitchenLabel">Horario de cocina</p>
            <p data-i18n="contacto.kitchenLine1">Lunes – Jueves: 13:00–16:00 / 20:00–23:00</p>
            <p data-i18n="contacto.kitchenLine2">Viernes – Sábado: 13:00–16:30 / 20:00–23:30</p>
            <p data-i18n="contacto.kitchenLine3">Domingo: 13:00–16:30 / 20:00–23:00</p>
          </div>
        </div>

        <a href="/reservas" class="cta-button" data-i18n="contacto.reservarCta">Reservar mesa</a>
      </div>

      <div class="map-wrapper" style="height: 460px; border-radius: 4px; overflow: hidden;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3037.2985!2d-3.700474!3d40.426440!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd422897b7c30f73%3A0x0!2sPlaza+de+Santa+B%C3%A1rbara%2C+4%2C+28004+Madrid!5e0!3m2!1ses!2ses!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Gran Café Santander en Google Maps"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="llegar-section">
    <div class="llegar-header">
      <h2 data-i18n="contacto.llegarTitle">Cómo llegar</h2>
    </div>
    <div class="llegar-inner">
      <div class="llegar-card">
        <span class="info-icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M4 16V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8" />
            <path d="M7 16v4" />
            <path d="M17 16v4" />
            <path d="M6 10h12" />
          </svg>
        </span>
        <h3 data-i18n="contacto.metroTitle">Metro</h3>
        <p data-i18n="contacto.metroDesc">Línea 4 (marrone), estación Alonso Martínez. 4 min caminando.</p>
      </div>
      <div class="llegar-card">
        <span class="info-icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M5 16h14" />
            <path d="M7 6h10l2 6H5l2-6z" />
            <path d="M7 16v2" />
            <path d="M17 16v2" />
          </svg>
        </span>
        <h3 data-i18n="contacto.busTitle">Bus</h3>
        <p data-i18n="contacto.busDesc">Líneas 3, 7, 14, 40. Parada Santa Bárbara.</p>
      </div>
      <div class="llegar-card">
        <span class="info-icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M6 7h12l1 5H5l1-5z" />
            <path d="M5 12v5h14v-5" />
            <path d="M8 12v5" />
            <path d="M16 12v5" />
          </svg>
        </span>
        <h3 data-i18n="contacto.parkingTitle">Aparcamiento 24/7</h3>
        <p data-i18n="contacto.parkingDesc">C. de Fernando el Santo, 11, Chamberí, 28010 a 5 min.</p>
      </div>
    </div>
  </section>
</BaseLayout>
